{
  "tests": [
    {
      "name": "Статус — список провайдеров",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": "ECSU AI 2.0",
      "bodyMatcher": "contains"
    },
    {
      "name": "Диалог — авто-выбор провайдера",
      "method": "POST",
      "path": "/",
      "body": {"message": "Привет", "session_id": "test-001", "history": [], "provider": "auto"},
      "expectedStatus": 200,
      "expectedBody": "reply",
      "bodyMatcher": "contains"
    },
    {
      "name": "DB — схема базы данных",
      "method": "POST",
      "path": "/",
      "body": {"db_action": "db_schema"},
      "expectedStatus": 200,
      "expectedBody": "schema",
      "bodyMatcher": "contains"
    },
    {
      "name": "DB — количество инцидентов",
      "method": "POST",
      "path": "/",
      "body": {"db_action": "db_count", "table": "incidents"},
      "expectedStatus": 200,
      "expectedBody": "count",
      "bodyMatcher": "contains"
    },
    {
      "name": "DB — статистика инцидентов",
      "method": "POST",
      "path": "/",
      "body": {"db_action": "db_stats", "table": "incidents"},
      "expectedStatus": 200,
      "expectedBody": "by_severity",
      "bodyMatcher": "contains"
    },
    {
      "name": "DB — недоступная таблица",
      "method": "POST",
      "path": "/",
      "body": {"db_action": "db_count", "table": "admin_users"},
      "expectedStatus": 400,
      "expectedBody": "error",
      "bodyMatcher": "contains"
    }
  ]
}