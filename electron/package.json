{
  "name": "ecsu-os",
  "version": "2.0.0",
  "description": "ECSU OS v2.0 — Гибридная операционная система. Nikolaev V.V.",
  "main": "main.js",
  "author": "Nikolaev Vladimir Vladimirovich",
  "license": "PRIVATE",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "dev.nikolaev.ecsu-os",
    "productName": "ECSU OS",
    "copyright": "© 2026 Nikolaev V.V.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ECSU OS"
    }
  }
}
